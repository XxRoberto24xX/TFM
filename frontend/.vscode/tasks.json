{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TypeScript: Compilar (tsc --noEmit)",
      "type": "shell",
      "command": "npx tsc --noEmit",
      "problemMatcher": ["$tsc"],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "ESLint: Revisar código",
      "type": "shell",
      "command": "npx eslint .",
      "problemMatcher": ["$eslint-stylish"],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Diagnóstico completo (TypeScript + ESLint)",
      "dependsOn": ["TypeScript: Compilar (tsc --noEmit)", "ESLint: Revisar código"],
      "dependsOrder": "parallel",
      "problemMatcher": ["$tsc", "$eslint-stylish"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
